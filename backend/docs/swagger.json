{
    "swagger": "2.0",
    "info": {
        "description": "Toei Transportation API",
        "title": "Train Status API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/fares": {
            "get": {
                "description": "Get IC card and ticket fare between two stations",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Fare"
                ],
                "summary": "Get fare",
                "parameters": [
                    {
                        "type": "string",
                        "example": "odpt.Station:Toei.Oedo.Daimon",
                        "description": "From station ID",
                        "name": "from",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "odpt.Station:Toei.Asakusa.Magome",
                        "description": "To station ID",
                        "name": "to",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.Fare"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/routes": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Railway"
                ],
                "summary": "Get railways",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/service.Railway"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/routes/{routeId}/stations": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Station"
                ],
                "summary": "Get stations by route",
                "parameters": [
                    {
                        "type": "string",
                        "example": "odpt.Railway:Toei.Asakusa",
                        "description": "Route ID",
                        "name": "routeId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/service.Station"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/stations/{stationId}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Station"
                ],
                "summary": "Get station detail",
                "parameters": [
                    {
                        "type": "string",
                        "example": "odpt.Station:Toei.Asakusa.Shimbashi",
                        "description": "Station ID",
                        "name": "stationId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.StationDetail"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/status": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Status"
                ],
                "summary": "Get Train Status",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/service.TrainStatus"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/trains/{trainNumber}/location": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Train"
                ],
                "summary": "Get train location",
                "parameters": [
                    {
                        "type": "string",
                        "example": "1965Ka",
                        "description": "Train Number",
                        "name": "trainNumber",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/service.TrainLocation"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health Check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "service.Fare": {
            "type": "object",
            "properties": {
                "from": {
                    "type": "string"
                },
                "icFare": {
                    "type": "integer"
                },
                "ticketFare": {
                    "type": "integer"
                },
                "to": {
                    "type": "string"
                }
            }
        },
        "service.Passenger": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "year": {
                    "type": "integer"
                }
            }
        },
        "service.Railway": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "service.Station": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "service.StationDetail": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "passengers": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/service.Passenger"
                    }
                },
                "timetable": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/service.Timetable"
                    }
                }
            }
        },
        "service.Timetable": {
            "type": "object",
            "properties": {
                "destination": {
                    "type": "string"
                },
                "time": {
                    "type": "string"
                },
                "trainNumber": {
                    "type": "string"
                }
            }
        },
        "service.TrainLocation": {
            "type": "object",
            "properties": {
                "delay": {
                    "type": "integer"
                },
                "fromStation": {
                    "type": "string"
                },
                "railway": {
                    "type": "string"
                },
                "toStation": {
                    "type": "string"
                },
                "trainNumber": {
                    "type": "string"
                }
            }
        },
        "service.TrainStatus": {
            "type": "object",
            "properties": {
                "railway": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}